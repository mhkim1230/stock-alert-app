# Single-user cloud deployment example

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
ADMIN_API_KEY=replace-with-long-random-string
DEBUG=false
AUTO_CREATE_TABLES=true
ALLOWED_ORIGINS=*
REQUEST_TIMEOUT=10
CACHE_TIMEOUT=300

APNS_USE_SANDBOX=true
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-team-id
APNS_BUNDLE_ID=com.example.stockalert
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Test DB must also be hosted PostgreSQL, never SQLite/local DB
TEST_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
TEST_ADMIN_API_KEY=replace-with-test-admin-key
